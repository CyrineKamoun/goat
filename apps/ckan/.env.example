CKAN_SITE_ID=default
CKAN_SITE_URL=http://localhost:5050
CKAN_PORT=5000
CKAN_SYSADMIN_NAME=admin
CKAN_SYSADMIN_PASSWORD=admin123
CKAN_SYSADMIN_EMAIL=admin@localhost

POSTGRES_USER=ckan
POSTGRES_PASSWORD=ckan
POSTGRES_DB=ckan
POSTGRES_HOST=db
CKAN_SQLALCHEMY_URL=postgresql://ckan:ckan@db/ckan
CKAN_DATASTORE_WRITE_URL=postgresql://ckan:ckan@db/datastore
CKAN_DATASTORE_READ_URL=postgresql://datastore_ro:datastore@db/datastore

CKAN_SOLR_URL=http://solr:8983/solr/ckan
SOLR_URL=http://solr:8983/solr/ckan

CKAN_REDIS_URL=redis://redis:6379/1

CKAN__PLUGINS=envvars stats image_view text_view recline_view datastore datapusher spatial_metadata spatial_query harvest ckan_harvester csw_harvester

CKAN__SPATIAL__SRID=4326
CKAN___CKANEXT__SPATIAL__SEARCH_BACKEND=solr-bbox
CKAN___CKANEXT__SPATIAL__COMMON_LOCALES=de,en

CKAN__HARVEST__MQ__TYPE=redis
CKAN__HARVEST__MQ__HOSTNAME=redis
CKAN__HARVEST__MQ__PORT=6379
CKAN__HARVEST__MQ__REDIS_DB=0
CKAN_HARVEST_SCHEDULE_SECONDS=3600

CKAN_STORAGE_PATH=/var/lib/ckan
CKAN__CORS__ORIGIN_ALLOW_ALL=true
CKAN_MAX_UPLOAD_SIZE_MB=100
